{
  "name": "real-time-chat",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently --raw -n typecheck,server -c yellow,cyan \"pnpm:typecheck:watch\" \"pnpm:dev:server\"",
    "dev:server": "ts-node-dev --respawn --transpile-only src/main.ts",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "prod": "tsc && node dist/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "redis": "^5.11.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}