# Environment variables configuration for the Real-Time Chat application.
# Copy this file to .env and fill in the appropriate values before running the application.

# Application configuration
PORT=3000

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6389
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=5000

# JWT configuration
JWT_SECRET_KEY=change_me_to_a_secure_random_string
